# Copy this file to .dev.vars for local development.
# GROQ_API_KEY_STANDALONE through GROQ_API_KEY_STANDALONE_3 are optional; if omitted, deterministic fallback replies are used.

GROQ_API_KEY_STANDALONE=
GROQ_API_KEY_STANDALONE_1=
GROQ_API_KEY_STANDALONE_2=
GROQ_API_KEY_STANDALONE_3=
GROQ_MODEL=llama-3.3-70b-versatile
RESEND_API_KEY=
EMAIL_FROM=
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:4173,https://relateiq-growth.pages.dev
